      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never"}, "unit": "reqps"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 23},
      "id": 9,
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "rate(churnguard_http_requests_total[5m])", "legendFormat": "{{method}} {{endpoint}} {{status_code}}", "refId": "A"}],
      "title": "HTTP Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never"}, "unit": "reqps"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 23},
      "id": 10,
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "rate(churnguard_http_errors_total[5m])", "legendFormat": "5xx — {{endpoint}}", "refId": "A"}],
      "title": "HTTP 5xx Error Rate",
      "type": "timeseries"
    }
  ],
